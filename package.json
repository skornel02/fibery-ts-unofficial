    "@types/node": "^25.9.1",
    "bottleneck": "^2.19.5",
    "ky": "^2.0.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.15",
    "vitest": "^4.0.0"
  },
  "volta": {
    "node": "24.14.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
